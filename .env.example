# ============================================================
# AGENCIA DE MARKETING — API KEYS
# Copia este archivo como .env y llena los valores
# ============================================================

# IMÁGENES Y VIDEO
PEXELS_API_KEY=                    # pexels.com/api — gratis
HIGGSFIELD_API_KEY=                # higgsfield.ai — generación de video IA

# AUDIO
ELEVENLABS_API_KEY=                # elevenlabs.io — voces IA premium
PIXABAY_API_KEY=                   # pixabay.com/api — música gratis
FREESOUND_API_KEY=                 # freesound.org — SFX
FREESOUND_CLIENT_ID=               # freesound.org — SFX

# INVESTIGACIÓN / SCRAPING
APIFY_TOKEN=                       # apify.com — scraping leads (Google Maps, IG, LinkedIn)

# PUBLICACIÓN AUTOMÁTICA
COMPOSIO_API_KEY=                  # app.composio.dev — conecta Instagram, WhatsApp, Notion, etc.
                                   # Ver sistema/COMPOSIO-SETUP.md para instrucciones completas

# OPCIONAL
OPENAI_API_KEY=                    # openai.com — si necesitas GPT para algún flujo
